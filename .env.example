# ====================================
# PDNS Manager – Umgebungsvariablen
# ====================================
# Kopiere diese Datei als .env und passe die Werte an:
#   cp .env.example .env
#
# WICHTIG:
# - Die .env wird NIE nach Git/GitHub hochgeladen (siehe .gitignore).
# - Trage hier echte Geheimnisse nur lokal ein. Auf einem produktiven Server
#   sollten alle Passwörter mit `openssl rand -base64 32` o. ä. erzeugt werden.
# - Das `install.sh`-Skript erzeugt die meisten Werte automatisch.

# ========================
# Datenbank (MariaDB)
# ========================
# Beide Passwörter müssen lang (mind. 24 Zeichen) und zufällig sein.
# Beispiel:  openssl rand -base64 32
DB_ROOT_PASSWORD=bitte-langes-zufaelliges-root-passwort
DB_NAME=dns_manager
DB_USER=dns_admin
DB_PASSWORD=bitte-langes-zufaelliges-passwort

# ========================
# PowerDNS Server (optional)
# ========================
# Format: name|url|api_key
# Mehrere Server mit Komma trennen: name1|url1|key1,name2|url2|key2
#
# Hinweis: Server können auch zur Laufzeit im Admin-Panel hinzugefügt werden.
# Die hier gesetzten Werte werden beim ersten Start einmalig in die Datenbank importiert.
PDNS_SERVERS=

# ========================
# App-Grundeinstellungen
# ========================
APP_NAME=PDNS Manager
# APP_VERSION wird ausschließlich aus der Datei VERSION im Projektroot gelesen.
LOG_LEVEL=info

# Standard-Sprache der Oberfläche
# DEFAULT_LANGUAGE=de

# Pfad auf dem HOST, in dem das Projekt liegt – wird unter „Einstellungen → Updates“ angezeigt.
# install.sh / setup.sh tragen den Wert automatisch ein.
# INSTALL_PATH=/home/user/dns-manager

# ========================
# Sicherheit
# ========================
# JWT-Geheimnis für Session-Cookies. PFLICHT auf einem produktiven Server.
# Wenn leer, wird beim Start eine Warnung ausgegeben – Sessions sind dann nach Neustart ungültig.
# Erzeugung:  openssl rand -hex 64
JWT_SECRET_KEY=

# Initiales Admin-Passwort (nur beim allerersten Start verwendet).
# Wenn leer, generiert das Backend ein Zufallspasswort und legt es in
# /app/.initial-admin-password (nur einmal lesbar) ab + im Container-Log.
# INITIAL_ADMIN_PASSWORD=

# Selbst-Registrierung über die /setup-Seite zulassen?
# Nur sinnvoll, wenn du das Setup zum ersten Mal durchläufst.
# Nach Anlage des ersten Admins wird die Registrierung automatisch deaktiviert.
ENABLE_REGISTRATION=false

# ========================
# Auth-Cookies
# ========================
# Setze AUTH_COOKIE_SECURE=true, sobald du HTTPS nutzt (Reverse-Proxy mit TLS).
# Für reinen lokalen Test über http://localhost darf der Wert „false“ bleiben.
AUTH_COOKIE_SECURE=false
# „lax“ ist sinnvoll, wenn Frontend und Backend unter dem gleichen Origin liegen
# (Standard-Setup). Für getrennte Domains musst du „none“ + AUTH_COOKIE_SECURE=true setzen.
AUTH_COOKIE_SAMESITE=lax

# ========================
# CORS / Web-Sicherheit
# ========================
# Komma-getrennte Liste erlaubter Origins für Cross-Origin-Anfragen, z. B.:
#   ALLOWED_ORIGINS=https://dns.example.com,https://intern.example.com
# Leer = kein Cross-Origin (empfohlen, wenn die SPA vom gleichen Backend gehostet wird).
ALLOWED_ORIGINS=

# OpenAPI-/Swagger-/ReDoc-UI öffentlich verfügbar machen?
# Standard: AUS, damit die API-Struktur nicht ungewollt einsehbar ist.
DOCS_ENABLED=false

# Ausgehende Webhooks blockieren standardmäßig localhost/private/internal IPs
# (SSRF-Schutz). Nur auf true setzen, wenn interne Webhook-Ziele bewusst erlaubt sind.
WEBHOOK_ALLOW_PRIVATE_URLS=false

# ========================
# Cookie-Lebensdauer
# ========================
# Maximale Login-Dauer in Sekunden (Default: 30 Tage = 2592000 s)
# AUTH_COOKIE_MAX_AGE=2592000
