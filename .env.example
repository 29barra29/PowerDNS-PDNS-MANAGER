# ====================================
# DNS Manager - Umgebungsvariablen
# ====================================
# Kopiere diese Datei als .env und passe die Werte an:
#   cp .env.example .env
#
# WICHTIG: Die .env Datei wird NICHT in Git hochgeladen!

# ========================
# Datenbank (MariaDB)
# ========================
DB_ROOT_PASSWORD=mein-sicheres-root-passwort
DB_NAME=dns_manager
DB_USER=dns_admin
DB_PASSWORD=mein-sicheres-db-passwort

# ========================
# PowerDNS Server (optional)
# ========================
# Format: name|url|api_key
# Mehrere Server mit Komma trennen: name1|url1|key1,name2|url2|key2
#
# Beispiel für einen Server:
# PDNS_SERVERS=ns1|http://192.168.1.10:8081|dein-api-key
#
# Beispiel für zwei Server:
# PDNS_SERVERS=ns1|http://10.0.0.1:8081|api-key-1,ns2|http://10.0.0.2:8081|api-key-2
#
# HINWEIS: Server können auch über das Admin-Panel hinzugefügt werden!
# Diese Variable ist nur für die initiale Einrichtung gedacht.
PDNS_SERVERS=

# ========================
# App Settings
# ========================
APP_NAME=DNS Manager
# APP_VERSION: absichtlich nicht hier – kommt ausschließlich aus der Datei VERSION im Projektroot
LOG_LEVEL=info

# Optional: Standard-Sprache der Oberfläche (wird von install.sh/setup.sh gesetzt)
# DEFAULT_LANGUAGE=de

# Optional: Installationspfad (wird in Einstellungen → Updates angezeigt)
# INSTALL_PATH=/pfad/zu/dns-manager
